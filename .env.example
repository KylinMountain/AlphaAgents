# ============================================================
# AlphaAgents 环境变量配置
# 复制为 .env 并填入你的 API Key
# ============================================================

# --- 快捷配置（一个 key 搞定 embedding + digest） ---
SILICONFLOW_API_KEY=sk-xxx           # 硅基流动免费 key: https://siliconflow.cn

# --- Embedding 模型（概念板块向量搜索） ---
# 默认用 SiliconFlow BGE-M3，也可换其他 OpenAI 兼容提供商
# EMBEDDING_API_KEY=sk-xxx           # 默认 fallback 到 SILICONFLOW_API_KEY
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3

# --- Digest 模型（新闻筛选聚合，便宜模型） ---
# 默认用 SiliconFlow Qwen，也可换 DeepSeek/Ollama/OpenAI 等
# DIGEST_API_KEY=sk-xxx              # 默认 fallback 到 SILICONFLOW_API_KEY
# DIGEST_BASE_URL=https://api.siliconflow.cn/v1
# DIGEST_MODEL=Qwen/Qwen2.5-7B-Instruct

# 示例: 用 DeepSeek
# DIGEST_API_KEY=sk-xxx
# DIGEST_BASE_URL=https://api.deepseek.com/v1
# DIGEST_MODEL=deepseek-chat

# 示例: 用本地 Ollama
# DIGEST_API_KEY=ollama
# DIGEST_BASE_URL=http://localhost:11434/v1
# DIGEST_MODEL=qwen2.5

# --- Agent 模型（策略师 & 地缘政治分析，需要 Claude 消息格式） ---
# 默认用 Anthropic Claude，也可用兼容 Claude 格式的提供商
ANTHROPIC_API_KEY=sk-ant-xxx         # Anthropic 官方
# AGENT_API_KEY=sk-xxx               # 默认 fallback 到 ANTHROPIC_API_KEY
# AGENT_BASE_URL=                    # 默认 fallback 到 ANTHROPIC_BASE_URL
# AGENT_MODEL=                       # 留空 = SDK 默认模型

# 示例: 用 OpenRouter (兼容 Claude 格式)
# AGENT_API_KEY=sk-or-xxx
# AGENT_BASE_URL=https://openrouter.ai/api/v1
# AGENT_MODEL=anthropic/claude-sonnet-4

# --- 监控设置 ---
# MONITOR_INTERVAL_SECONDS=300       # 新闻轮询间隔（秒）
# NEWS_FETCH_LIMIT=50                # 每个源每次最多拉取条数
